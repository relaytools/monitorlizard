# INFLUXDB_URL=
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=
# INFLUXDB_BUCKET=
# INFLUXDB_MEASUREMENT=
MONITOR_NAME=myrelaymonitor
NOSTR_PUBLISH=true
NOSTR_PRIVATE_KEY=
# Profile relays (Kind 0, 10002) - for monitor name/profile discovery
NOSTR_PUBLISH_PROFILE_RELAYS=wss://purplepag.es,wss://relay.primal.net,wss://relay.damus.io
# Metrics relays (Kind 10166, 30166) - for relay monitoring data
NOSTR_PUBLISH_METRICS_RELAYS=wss://relay.nostr.watch,wss://relay.primal.net,wss://relay.damus.io
NOSTR_PUBLISH_MONITOR_PROFILE=true
MONITOR_COUNTRY_CODE=US
MONITOR_COUNTRY_NAME=United States of America
MONITOR_CITY_NAME=Seattle
MONITOR_ABOUT=Relay Monitor
# Frequency to run and publish checks (seconds)
MONITOR_FREQUENCY=300
# How often to refresh NIP-11 relay info (seconds, default 600 = 10 minutes)
NIP11_REFRESH_INTERVAL=600
# relaymonitor geoencodes this for you and encodes to a low
# precision (general area or country)
# the lat, long of the monitor location
MONITOR_LATITUDE=47.620564
MONITOR_LONGITUDE=-122.350616
# this is the lat,long of the relay(s) location
RELAY_LATITUDE=43.000000
RELAY_LONGITUDE=-75.000000
# optional specify one or more relays (or use command line option)
RELAY_URLS=wss://myrelay1.com,wss://myrelay2.com
