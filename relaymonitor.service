[Unit]
Description=Nostr Relay Monitor (NIP-66)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/relaymonitor
WorkingDirectory=/usr/local/etc
Restart=always
RestartSec=10

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
