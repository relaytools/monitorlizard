INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=
INFLUXDB_MEASUREMENT=
MONITOR_NAME=mylizard
NOSTR_PUBLISH=true
NOSTR_PRIVATE_KEY=
NOSTR_PUBLISH_RELAY_METRICS=wss://monitorlizard.nostr1.com
NOSTR_PUBLISH_MONITOR_PROFILE=true
MONITOR_COUNTRY_CODE=US
MONITOR_COUNTRY_NAME=United States of America
MONITOR_CITY_NAME=Seattle
MONITOR_ABOUT=Relay Monitor new Lizard
MONITOR_FREQUENCY=300
# monitorlizard geoencodes this for you and encodes to a low
# precision (general area or country)
# the lat, long of the monitor location
MONITOR_LATITUDE=47.620564
MONITOR_LONGITUDE=-122.350616
# this is the lat,long of the relay(s) location
RELAY_LATITUDE=43.000000
RELAY_LONGITUDE=-75.000000
# optional specify one or more relays (or use command line option)
# append ;type after any URL to advertise the relay type via a T tag on kind 30166 events
# omit ;type to publish no T tag for that relay
# valid type values (PascalCase):
#   PublicOutbox   - stores all public content of a user (NIP-65 outbox)
#   PublicInbox    - accepts events p-tagging subscribers, readable by anyone (NIP-65 inbox)
#   PrivateInbox   - accepts events p-tagging subscribers, only tagged user can download (DMs, NWC, DVM)
#   PrivateStorage - author-only read/write storage (drafts, private settings)
#   Search         - implements NIP-50 full-text search
#   Directory      - tracks kind 0 and kind 10002 only (people/relay discovery)
#   Community      - NIP-29 group or NIP-71 community relay
#   Algo           - returns events in operator-defined order (algorithmic feeds)
#   Archival       - archival/backup node for the network
#   LocalCache     - private storage relay with low-latency local proximity
#   Blob           - binary/NIP-95 content storage
#   Broadcast      - re-broadcasts events to other relays (blastr-style)
#   Proxy          - aggregator proxy sustaining one client connection to many relays (bostr-style)
#   Trusted        - stores non-verifiable events (decrypted NIP-17 DMs) with strong auth
#   Push           - ephemeral push-notification relay, not queryable
RELAY_URLS=wss://myrelay1.com;PublicOutbox,wss://myrelay2.com;Search,wss://myrelay3.com